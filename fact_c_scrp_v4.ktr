        <jsScript_script>//Calculate_Duration

var duration_days = end_date - start_date;

var sd = new Date(String(start_date).substring(0,4), String(start_date).substring(4,6)-1, String(start_date).substring(6,8));
var ed = new Date(String(end_date).substring(0,4), String(end_date).substring(4,6)-1, String(end_date).substring(6,8));
var duration_days = Math.round((ed - sd) / (1000*60*60*24));</jsScript_script>
