  <step>
    <name>Calculate_USD</name>
    <type>ScriptValueMod</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <compatible>N</compatible>
    <optimizationLevel>9</optimizationLevel>
    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>//converting currencies into USD

var unit_price_usd = price * currency_rate;
var unit_cost_usd = unit_cost * currency_rate;
var sales_usd = qty * price * currency_rate;
var sales_cost_usd = qty * unit_cost * currency_rate;
var sales_margin_usd = sales_usd - sales_cost_usd;</jsScript_script>
      </jsScript>
    </jsScripts>
    <fields>
      <field>
        <name>unit_price_usd</name>
        <rename>unit_price_usd</rename>
        <type>Number</type>
        <length>-1</length>
        <precision>-1</precision>
        <replace>N</replace>
      </field>
      <field>
        <name>unit_cost_usd</name>
        <rename>unit_cost_usd</rename>
        <type>Number</type>
        <length>-1</length>
        <precision>-1</precision>
        <replace>N</replace>
      </field>
      <field>
        <name>sales_usd</name>
        <rename>sales_usd</rename>
        <type>Number</type>
        <length>-1</length>
        <precision>-1</precision>
        <replace>N</replace>
      </field>
      <field>
        <name>sales_cost_usd</name>
        <rename>sales_cost_usd</rename>
        <type>Number</type>
        <length>-1</length>
        <precision>-1</precision>
        <replace>N</replace>
      </field>
      <field>
        <name>sales_margin_usd</name>
        <rename>sales_margin_usd</rename>
        <type>Number</type>
        <length>-1</length>
